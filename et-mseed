import numpy as np 
import matplotlib.pyplot as plt
from obspy import read
from obspy.clients.fdsn import Client
from pathlib import Path

"""
The files ET-mseed/eida_response_MN-SENA_20240101000000_20240131000000.mseed and ET-mseed/eida_response_MN-SENA_20240101000000_20240202000000.mseed correspond to SENA data
The data is from 01-01-2024 to 02-02-2024 (DD-MM-YYYY)


All of the other files correspond to Einstein Telescope Tests, which are available at https://eida.ingv.it/en/getdata/3M_2024 and are from 01-11-2024 to 02-11-2025 (DD-MM-YYYY)
It is important to point out that the first leters "FAB??" correspond to the respective station code of the network 3M_2024, available at https://www.orfeus-eu.org/stationbook/networks/3M/2024/
All of them are "HH?" type, which means "High Broadband" or "High-Gain Broadband"
The tird letter "Z/N/E" stands for the orientation Vertical/North-South/East-Weast
More information about the naming convention is available at https://epic.earthscope.org/webfm_send/2134
You can also check https://docs.obspy.org/tutorial/index.html for a quick tutorial on how Obspy works 
"""

# ET files

input_dir = Path("/home/rauls/Desktop/VirgoBRET/ET-mseed/")
output_dir = Path("ET-mseed-plots")
output_dir.mkdir(exist_ok=True)

mseed_files = sorted(input_dir.glob("*.mseed"))
mseed_files = [f for f in mseed_files if f.name != "eida_response_20241101000000_20260323000000.mseed"] #Excluding the 1gb file 
#print(mseed_files)


for file in mseed_files:
    print("\nProcessing:", file.name)

    try:
        st = read(str(file))
        st.sort(keys=["channel"])

        for tr in st:
            tr.detrend("linear")
            tr.detrend("demean")

        channels = ["HHE", "HHN", "HHZ"]
        selected_traces = []

        for ch in channels:
            tr = st.select(channel=ch)
            if len(tr) > 0:
                selected_traces.append(tr[0])
            
        n = len(selected_traces)

        fig, axes = plt.subplots(n, 1, figsize=(12, 8), sharex=True)

        if n == 1:
            axes = [axes]  # ensure iterable

        for ax, tr in zip(axes, selected_traces):
            t = np.linspace(0, tr.stats.npts / tr.stats.sampling_rate, tr.stats.npts)

        ax.plot(t, tr.data)
        ax.set_ylabel(tr.stats.channel)
        ax.grid()

        axes[-1].set_xlabel("Time (s)")

        fig.suptitle(file.stem)
        outfile = output_dir / f"{file.stem}_3components.pdf"
        plt.savefig(outfile)
        plt.close(fig)
        print(f"Saved: {outfile}")

    except Exception as e:

        print("Failed:", e)
        continue

